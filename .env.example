# =============================================================================
# AI Research Intelligence System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# =============================================================================
# API KEYS (Optional - System works without them but with limitations)
# =============================================================================

# OpenAI API Key
# Purpose: Enhanced writing suggestions, paraphrasing, and AI-powered analysis
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Semantic Scholar API Key
# Purpose: Higher rate limits for academic paper search and citation analysis
# Get it from: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# CrossRef API Key
# Purpose: Higher rate limits for DOI and reference lookup
# Get it from: https://www.crossref.org/services/metadata-delivery/rest-api/
CROSSREF_API_KEY=

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Log file path (leave empty to log to console only)
# LOG_FILE=logs/app.log

# =============================================================================
# ANALYSIS SETTINGS
# =============================================================================

# Default analysis depth: Quick, Standard, Deep
DEFAULT_ANALYSIS_DEPTH=Standard

# Enable caching for API responses (true/false)
ENABLE_API_CACHING=true

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# Maximum number of reference papers to fetch from APIs
MAX_REFERENCE_PAPERS=10

# =============================================================================
# PLAGIARISM DETECTION SETTINGS
# =============================================================================

# Rabin-Karp window size (3-15, default: 5)
RABIN_KARP_WINDOW_SIZE=5

# TF-IDF n-gram range (format: "min,max", default: "1,3")
# TFIDF_NGRAM_RANGE=1,3

# Semantic similarity model name
SEMANTIC_MODEL_NAME=all-MiniLM-L6-v2

# Plagiarism thresholds (0.0-1.0)
PLAGIARISM_THRESHOLD_LOW=0.15
PLAGIARISM_THRESHOLD_MEDIUM=0.35
PLAGIARISM_THRESHOLD_HIGH=0.60

# =============================================================================
# QUALITY ANALYSIS SETTINGS
# =============================================================================

# Minimum citation count for quality assessment
MIN_CITATION_COUNT=5

# Target readability grade level (1.0-20.0)
READABILITY_TARGET_GRADE=12.0

# Tone formality threshold (0.0-1.0)
TONE_FORMALITY_THRESHOLD=0.7

# =============================================================================
# FILE PROCESSING SETTINGS
# =============================================================================

# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Supported file types (comma-separated)
# SUPPORTED_FILE_TYPES=.pdf,.docx,.txt

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Enable multiprocessing (true/false)
ENABLE_MULTIPROCESSING=true

# Maximum number of worker processes (1-16)
MAX_WORKERS=4

# Chunk size for batch processing
CHUNK_SIZE=1000

# =============================================================================
# API RATE LIMITING
# =============================================================================

# API rate limit: calls per period
API_RATE_LIMIT_CALLS=100

# API rate limit period in seconds
API_RATE_LIMIT_PERIOD=60

# API request timeout in seconds
API_TIMEOUT_SECONDS=30

# Maximum API retry attempts
API_MAX_RETRIES=3

# =============================================================================
# ADVANCED SETTINGS (Usually don't need to change)
# =============================================================================

# Hybrid model weights (must sum to 1.0)
# Format: alpha,beta,gamma,delta
# HYBRID_WEIGHTS=0.3,0.2,0.3,0.2

# Section weights for analysis
# Format: section:weight,section:weight
# SECTION_WEIGHTS=abstract:0.8,introduction:1.0,literature_review:1.2

# =============================================================================
# NOTES
# =============================================================================
# 
# API Status Without Keys:
# ✅ arXiv: Works immediately (no key required)
# ✅ Wikipedia: Works immediately (no key required)
# ✅ LanguageTool: Works immediately (no key required)
# ⚠️  Semantic Scholar: Works with rate limits
# ⚠️  CrossRef: Works with rate limits
# ❌ OpenAI Features: Disabled without key
#
# For detailed setup instructions, see SETUP_GUIDE.md
# =============================================================================
