# Streamlit Secrets Configuration Example
# Copy this to secrets.toml and add your API keys
# DO NOT commit secrets.toml to git!

# OpenAI API (Optional - for enhanced analysis)
OPENAI_API_KEY = "sk-your-key-here"

# Semantic Scholar API (Optional - for paper search)
SEMANTIC_SCHOLAR_API_KEY = "your-key-here"

# CrossRef API (Optional - for citation validation)
CROSSREF_API_KEY = "your-key-here"

# Note: The app works WITHOUT these keys!
# Free APIs (arXiv, Wikipedia, LanguageTool) are always available
